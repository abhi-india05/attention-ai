# AttentionX Environment Configuration
# Copy this to .env and fill in your values

# ── LLM Provider ────────────────────────────────────────────────
# Choose: "openai" or "gemini"
LLM_PROVIDER=openai

# ── API Keys ─────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
GEMINI_API_KEY=your-gemini-key-here

# ── Whisper Model ─────────────────────────────────────────────────
# Options: tiny (fastest) | base | small | medium | large (most accurate)
# For hackathon demo: "base" is the sweet spot (speed vs accuracy)
WHISPER_MODEL=base
