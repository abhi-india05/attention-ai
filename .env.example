# AttentionX Environment Configuration
# Copy this to .env and fill in your values

# ── API Keys ─────────────────────────────────────────────────────
# Gemini powers all LLM features in this project.
# Provide one or more keys. Separate multiple keys with commas or new lines.
GEMINI_API_KEYS=your-gemini-key-1,your-gemini-key-2
# Optional legacy fallback for single-key setups:
# GEMINI_API_KEY=your-gemini-key-here
GROQ_API_KEY=your-groq-api-key-here

# ── Groq Whisper Model ────────────────────────────────────────────
# Options: whisper-large-v3 (best accuracy) | whisper-large-v3-turbo (faster)
WHISPER_MODEL=whisper-large-v3
